# ============================================================
# JamberTech E-SERVICES — Environment Variables Template
# ============================================================
# Is file ko copy karke ".env" naam do:
#   cp .env.example .env
# Phir apni real values bharo.
# .env file KABHI GitHub par push mat karna!
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/jambertech

# ── AUTH ─────────────────────────────────────────────────────
# JWT signing secret - ek strong random string rakho (min 32 chars)
# Generate karne ke liye: openssl rand -base64 32
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars

# ── EMAIL (Resend) ───────────────────────────────────────────
# Resend account se API key lo: https://resend.com
# Dashboard > API Keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender email address (tumhara verified domain hona chahiye Resend mein)
FROM_EMAIL=noreply@yourdomain.com

# ── SERVER ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── LOGGING ──────────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
